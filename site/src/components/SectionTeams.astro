---
import Card from '@components/Card.astro'
---

<section class="py-6xlarge">
  <div class="container">
    <div class="row justify-content-center mb-5xlarge">
      <div class="col-large-8 text-center">
        <h2 class="font-hero mb-medium lh-small">
          <span class="font-normal">Why Leading Teams Choose</span>
          <span class="text-nowrap">Chassis CSS</span>
        </h2>
        <p class="font-lead">
          Chassis CSS gives your team a production-ready foundation for building consistent, accessible interfaces across brands and products with less code and better performance.
        </p>
      </div>
    </div>

    <div class="row row-cols-1 row-cols-medium-3">
      <div class="col">
        <Card
          title="Faster Development"
          body="Build responsive layouts in minutes with comprehensive utilities, components, and grid system. Ship features faster without writing custom CSS."
          icon="clock-outline"
        />
      </div>
      <div class="col">
        <Card
          title="Design Consistency"
          body="Token-driven architecture ensures perfect brand consistency across all interfaces. Design decisions flow directly from tokens to components."
          icon="check-circle-outline"
        />
      </div>
      <div class="col">
        <Card
          title="Enterprise Scale"
          body="Multi-brand support, theme switching, RTL layouts, and accessibility built-in. Scale from one app to entire product families."
          icon="code-outline"
        />
      </div>
    </div>
  </div>
</section>
