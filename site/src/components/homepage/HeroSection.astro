---
import { getConfig } from '@libs/config'
import Code from '@shortcodes/Code.astro'
import { getChassisDocsPath } from '@libs/path'
---

<section class="home-section py-3xlarge py-medium-6xlarge">
  <div class="container-2xlarge section-content py-3xlarge py-medium-6xlarge">
    <div class="row justify-content-center mb-3xlarge mb-medium-6xlarge">
      <div class="col col-xlarge-10 text-center">
        <p
          class="module-title fg-primary font-small font-medium-medium font-mass text-uppercase mb-xsmall mb-medium-small"
        >
          CHASSIS CSS
        </p>
        <h1 class="font-hero mb-small mb-medium-medium mb-large-large">
          <span class="font-normal">Token-Driven CSS Framework</span>
          <span class="d-block">for Multi-Brand Design Systems</span>
        </h1>
        <p class="font-lead mb-medium mb-medium-large">
          Complete CSS framework built on Chassis Tokens. Automatic Figma Variable sync, responsive
          grid system, 50+ accessible components, and utilities for rapid development across
          multiple brands and themes.
        </p>
      </div>
    </div>

    <div
      class="d-flex flex-column gap-medium mb-medium mb-medium-large col col-large-6 offset-large-3"
    >
      <!-- Code snippet -->
      <Code lang="bash" code="npm install @chassis-ui/css" />
      <!-- Buttons -->
      <div class="d-grid d-medium-flex gap-medium justify-content-medium-center flex-wrap">
        <a href="/getting-started" class="button primary large">
          <svg class="icon" aria-hidden="true"><use href="#book-open-solid"></use></svg>
          <span>Get Started</span>
        </a>
        <a
          href="https://github.com/chassis-ui/css"
          class="button default large"
          target="_blank"
          rel="noopener"
        >
          <svg class="icon" aria-hidden="true"><use href="#github-brand"></use></svg>
          <span>View on GitHub</span>
        </a>
      </div>

      <!-- Version info -->
      <p class="fg-subtle mb-0 text-center font-medium">
        Currently <strong>v{getConfig().current_version}</strong>
        <span class="px-2xsmall">&middot;</span>
        <a href={getChassisDocsPath('getting-started/download')} class="link-secondary">Download</a>
        <span class="px-2xsmall">&middot;</span>
        <a href="/docs/versions/" class="link-secondary text-nowrap">All releases</a>
      </p>
    </div>
  </div>
</section>
