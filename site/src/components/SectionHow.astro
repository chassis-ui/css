<section class="bg-even py-6xlarge">
  <div class="container py-6xlarge">
    <div class="row justify-content-center mb-5xlarge">
      <div class="col-large-8 text-center">
        <h2 class="font-hero mb-medium">How It Works</h2>
        <p class="font-lead">
          Chassis CSS follows a simple three-step workflow that connects design tokens to
          production-ready CSS components with full theme support.
        </p>
      </div>
    </div>

    <div class="row g-3xlarge">
      <div class="col-large-4">
        <div class="card rounded-xlarge">
          <div class="card-content">
            <div class="text-center mb-small">
              <span class="font-3xlarge font-strong fg-primary">1</span>
            </div>
            <h3 class="h4 mb-medium text-center">Install & Configure</h3>
            <p class="text-center text-context-default-fg-subtle">
              Install via npm or CDN. Configure your brand tokens and theme settings. Import the
              core CSS or individual components.
            </p>
          </div>
        </div>
      </div>

      <div class="col-large-4">
        <div class="card rounded-xlarge">
          <div class="card-content">
            <div class="text-center mb-small">
              <span class="font-3xlarge font-strong fg-primary">2</span>
            </div>
            <h3 class="h4 mb-medium text-center">Build Your Interface</h3>
            <p class="text-center text-context-default-fg-subtle">
              Use components, utilities, and grid system to build responsive layouts. Customize with
              SCSS variables or CSS custom properties.
            </p>
          </div>
        </div>
      </div>

      <div class="col-large-4">
        <div class="card rounded-xlarge">
          <div class="card-content">
            <div class="text-center mb-large">
              <span class="font-3xlarge font-strong fg-primary">3</span>
            </div>
            <h3 class="h4 mb-medium text-center">Ship & Scale</h3>
            <p class="text-center text-context-default-fg-subtle">
              Deploy with confidence. Add new brands or themes anytime. Tree-shake unused CSS for
              optimal performance.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
