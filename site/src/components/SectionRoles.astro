---
import Card from '@components/Card.astro'
---

<section class="bg-even py-6xlarge">
  <div class="container py-6xlarge">
    <div class="row justify-content-center mb-5xlarge">
      <div class="col-large-8 text-center my-4xlarge">
        <h2 class="font-hero mb-medium">Built for Your Role</h2>
        <p class="font-lead">
          Whatever your role is, Chassis CSS accelerates development and ensures consistency across
          your entire product portfolio.
        </p>
      </div>
    </div>

    <div class="row pb-6xlarge">
      <!-- Product Managers -->
      <div class="col-large-4">
        <div class="feature-thumb">
          <svg class="icon feature-icon"><use href="#briefcase-outline"></use></svg>
        </div>
        <h3 class="h4 mb-medium">Product Managers</h3>
        <ul class="list-group list-unstyled">
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Launch new products faster with ready-made components</span>
          </li>
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Maintain brand consistency across entire portfolio</span>
          </li>
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Reduce time-to-market with battle-tested patterns</span>
          </li>
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Scale design system without scaling team size</span>
          </li>
        </ul>
      </div>

      <!-- Design Leads -->
      <div class="col-large-4">
        <div class="feature-thumb">
          <svg class="icon feature-icon"><use href="#palette-outline"></use></svg>
        </div>
        <h3 class="h4 mb-medium">Design Leads</h3>
        <ul class="list-group list-unstyled">
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Direct token-to-component mapping ensures fidelity</span>
          </li>
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Customizable theme system for multi-brand design</span>
          </li>
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Accessible by default with WCAG AA compliance</span>
          </li>
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Responsive utilities for mobile-first experiences</span>
          </li>
        </ul>
      </div>

      <!-- CTOs -->
      <div class="col-large-4">
        <div class="feature-thumb">
          <svg class="icon feature-icon"><use href="#code-outline"></use></svg>
        </div>
        <h3 class="h4 mb-medium">CTOs & Tech Leads</h3>
        <ul class="list-group list-unstyled">
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Framework-agnostic, works with any JavaScript library</span>
          </li>
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Modular architecture with tree-shakable components</span>
          </li>
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Modern build pipeline with SCSS and PostCSS</span>
          </li>
          <li class="d-flex gap-small">
            <span class="icon icon-check-circle-outline success-icon-main"></span>
            <span>Production-tested with comprehensive browser support</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
