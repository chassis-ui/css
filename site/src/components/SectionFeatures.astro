---
import Card from '@components/Card.astro'
---

<section class="py-6xlarge">
  <div class="container">
    <div class="row justify-content-center mb-5xlarge">
      <div class="col-large-8 text-center">
        <h2 class="font-hero mb-medium">Enterprise-Grade Features</h2>
        <p class="font-lead">
          A comprehensive CSS framework with components, utilities, and layout systems designed for
          large-scale applications and multi-brand design systems.
        </p>
      </div>
    </div>

    <div class="row row-cols-1 row-cols-medium-2 g-xlarge">
      <div class="col">
        <Card
          title="Token-Driven Architecture"
          body="Built on Chassis Tokens foundation. Every color, spacing, and typography value references design tokens for perfect brand consistency."
          icon="swatchbook-outline"
        />
      </div>
      <div class="col">
        <Card
          title="Multi-Brand Support"
          body="Switch brands instantly with theme variables. Manage multiple brand identities from a single codebase with zero code changes."
          icon="palette-outline"
        />
      </div>
      <div class="col">
        <Card
          title="Comprehensive Components"
          body="Buttons, cards, modals, navigation, forms, and more. Battle-tested components ready for production with full customization."
          icon="grid-outline"
        />
      </div>
      <div class="col">
        <Card
          title="Powerful Grid System"
          body="Flexible 12-column grid with responsive breakpoints. Build any layout with gap utilities, auto-layout, and nested grids."
          icon="layout-outline"
        />
      </div>
      <div class="col">
        <Card
          title="Utility-First Approach"
          body="Hundreds of utility classes for spacing, typography, colors, and more. Build custom designs without writing CSS."
          icon="code-outline"
        />
      </div>
      <div class="col">
        <Card
          title="Accessibility Built-In"
          body="WCAG AA compliant components with proper ARIA attributes, keyboard navigation, and focus management out of the box."
          icon="accessibility-outline"
        />
      </div>
    </div>
  </div>
</section>
