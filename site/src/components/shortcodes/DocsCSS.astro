---
interface Props {
  /**
   * Name shown in the description, e.g. "Accordion". Omit for the
   * generic fallback ("This component" / "These utilities", etc.).
   */
  name?: string
  /**
   * The kind of thing being documented.
   * @default 'component'
   */
  type?: 'component' | 'helper' | 'utility' | 'system'
  /**
   * Use plural phrasing — "Form components" instead of "The Form component".
   * @default false
   */
  plural?: boolean
  /**
   * When true, the component is also can be configured through exposed
   * CSS custom properties at runtime.
   * @default false
   */
  exposed?: boolean
}

const { name, type = 'component', plural = false, exposed = false } = Astro.props

const noun = plural ? (type === 'utility' ? 'utilities' : `${type}s`) : type

const subject = !name
  ? plural
    ? `These ${noun}`
    : `This ${noun}`
  : plural
    ? `${name} ${noun}`
    : `The ${name} ${noun}`
---

{
  exposed ? (
    <p>
      {subject} can be customized at both runtime (via custom properties) and compile time (via Sass
      variables).
    </p>
  ) : (
    <p>{subject} can be customized through Sass variables at compile time.</p>
  )
}
