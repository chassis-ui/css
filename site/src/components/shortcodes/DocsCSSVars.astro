---
import { getConfig } from '@libs/config'

interface Props {
  /**
   * Name shown in the description, e.g. "Accordion". Omit for the
   * generic fallback ("This component exposes" / "These utilities expose", etc.).
   */
  name?: string
  /**
   * The kind of thing being documented.
   * @default 'component'
   */
  type?: 'component' | 'helper' | 'utility' | 'system'
  /**
   * Use plural phrasing — "Form components expose" instead of "The Form component exposes".
   * @default false
   */
  plural?: boolean
  /**
   * Whether to include the cascading variables pattern in the description.
   * Set to false for components that don't follow this pattern.
   * @default false
   */
  cascading?: boolean
}

const { name, type = 'component', plural = false, cascading = false } = Astro.props

const noun = plural ? (type === 'utility' ? 'utilities' : `${type}s`) : type

const subject = !name
  ? plural
    ? `These ${noun}`
    : `This ${noun}`
  : plural
    ? `${name} ${noun}`
    : `The ${name} ${noun}`

const opener = `${subject} expose${plural ? '' : 's'}`
const possessive = plural ? 'their' : 'its'
---

<p>
  {opener} CSS custom properties to control {possessive} appearance at runtime.
  {
    cascading && (
      <>
        {' '}
        They follow the{' '}
        <a href="https://www.w3.org/TR/css-variables-1/#example-c3e4e8d9">
          cascading variables
        </a>{' '}
        pattern, inheriting values from a{' '}
        <a href={`${getConfig().docsPath}/core-concepts/context-class`}>context class</a> or any
        parent element.
      </>
    )
  }
</p>
