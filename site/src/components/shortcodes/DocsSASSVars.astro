---
import { getConfig } from '@libs/config'

interface Props {
  /**
   * Name shown in the description, e.g. "Accordion". Omit for the
   * generic fallback ("This component uses" / "These utilities use", etc.).
   */
  name?: string
  /**
   * The kind of thing being documented.
   * @default 'component'
   */
  type?: 'component' | 'helper' | 'utility'
  /**
   * Use plural phrasing — "Form components use" instead of "The Form component uses".
   * @default false
   */
  plural?: boolean
  /**
   * When true, the Sass variables are also exposed as CSS custom properties.
   * @default false
   */
  exposed?: boolean
}

const { name, type = 'component', plural = false, exposed = false } = Astro.props

const noun = plural ? (type === 'utility' ? 'utilities' : `${type}s`) : type

const subject = !name
  ? plural
    ? `These ${noun}`
    : `This ${noun}`
  : plural
    ? `${name} ${noun}`
    : `The ${name} ${noun}`

const opener = `${subject} use${plural ? '' : 's'}`
const possessive = plural ? 'their' : 'its'
---

{
  exposed ? (
    <p>
      {opener} Sass variables in <code>scss/config/_defaults.scss</code> to define {possessive}{' '}
      defaults; they are also exposed as CSS custom properties using the <code>--cx-</code> prefix
      for runtime override — <code>$variable-name</code> becomes <code>--cx-variable-name</code>.
      See the{' '}
      <a href={`${getConfig().docsPath}/core-concepts/component-anatomy`}>component anatomy</a>{' '}
      page.
    </p>
  ) : (
    <p>
      {opener} Sass variables in <code>scss/config/_defaults.scss</code> to define {possessive}{' '}
      defaults.
    </p>
  )
}
