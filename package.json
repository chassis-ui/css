{
  "name": "@chassis-ui/css",
  "description": "A CSS framework which synchronizes with Figma components by using design tokens.",
  "version": "0.1.0",
  "type": "module",
  "config": {
    "version_short": "0.1"
  },
  "keywords": [
    "css",
    "sass",
    "mobile-first",
    "responsive",
    "front-end",
    "framework",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chassis-ui/css.git"
  },
  "bugs": {
    "url": "https://github.com/chassis-ui/css/issues"
  },
  "homepage": "https://chassis-ui.com",
  "author": "Ozgur Gunes <o.gunes@gmail.com>",
  "license": "MIT",
  "main": "dist/js/chassis.js",
  "module": "dist/js/chassis.esm.js",
  "sass": "scss/chassis.scss",
  "style": "dist/css/chassis.css",
  "scripts": {
    "build": "pnpm dist && pnpm site:build",
    "dev": "pnpm watch & pnpm astro:dev",
    "dist": "pnpm css & pnpm js & wait",
    "postinstall": "pnpm sync:submodules",
    "start": "pnpm dev",
    "test": "pnpm check:code && pnpm dist && pnpm css:test && pnpm js:test && pnpm site:build && pnpm site:lint",
    "css": "pnpm css:compile && pnpm css:prefix && pnpm css:rtl && pnpm css:minify",
    "css:compile": "sass --style expanded --source-map --embed-sources --no-error-css scss/:dist/css/",
    "css:lint": "pnpm css:lint:stylelint & pnpm css:lint:vars & wait",
    "css:lint:stylelint": "stylelint \"**/*.{css,scss}\" --cache --cache-location .cache/.stylelintcache",
    "css:lint:vars": "fusv scss/ site/src/scss/",
    "css:minify": "pnpm css:minify:main & pnpm css:minify:rtl & wait",
    "css:minify:main": "cleancss -O1 --format breakWith=lf --with-rebase --source-map --source-map-inline-sources --output dist/css/ --batch --batch-suffix \".min\" \"dist/css/*.css\" \"!dist/css/*.min.css\" \"!dist/css/*rtl*.css\"",
    "css:minify:rtl": "cleancss -O1 --format breakWith=lf --with-rebase --source-map --source-map-inline-sources --output dist/css/ --batch --batch-suffix \".min\" \"dist/css/*rtl.css\" \"!dist/css/*.min.css\"",
    "css:prefix": "postcss --config build/postcss.config.js --replace \"dist/css/*.css\" \"!dist/css/*.rtl*.css\" \"!dist/css/*.min.css\"",
    "css:rtl": "cross-env NODE_ENV=RTL postcss --config build/postcss.config.js --dir \"dist/css\" --ext \".rtl.css\" \"dist/css/*.css\" \"!dist/css/*.min.css\" \"!dist/css/*.rtl.css\"",
    "css:test": "node scss/tests/runner.js",
    "js": "pnpm js:compile && pnpm js:minify",
    "js:compile": "pnpm js:compile:bundle & pnpm js:compile:esm & pnpm js:compile:umd & pnpm js:compile:plugins & wait",
    "js:compile:bundle": "rollup --environment BUNDLE:true --config build/rollup.config.js --sourcemap",
    "js:compile:esm": "rollup --environment ESM:true,BUNDLE:false --config build/rollup.config.js --sourcemap",
    "js:compile:plugins": "node build/build-plugins.js",
    "js:compile:umd": "rollup --environment BUNDLE:false --config build/rollup.config.js --sourcemap",
    "js:lint": "eslint --cache --cache-location .cache/.eslintcache --report-unused-disable-directives --ext .html,.js,.cjs,.mjs,.md .",
    "js:minify": "pnpm js:minify:bundle & pnpm js:minify:esm & pnpm js:minify:umd & wait",
    "js:minify:bundle": "terser --compress passes=2 --mangle --comments \"/^!/\" --source-map \"content=dist/js/chassis.bundle.js.map,includeSources,url=chassis.bundle.min.js.map\" --output dist/js/chassis.bundle.min.js dist/js/chassis.bundle.js",
    "js:minify:esm": "terser --compress passes=2 --mangle --comments \"/^!/\" --source-map \"content=dist/js/chassis.esm.js.map,includeSources,url=chassis.esm.min.js.map\" --output dist/js/chassis.esm.min.js dist/js/chassis.esm.js",
    "js:minify:umd": "terser --compress passes=2 --mangle --comments \"/^!/\" --source-map \"content=dist/js/chassis.js.map,includeSources,url=chassis.min.js.map\" --output dist/js/chassis.min.js dist/js/chassis.js",
    "js:test": "pnpm js:test:karma & pnpm js:test:jquery & pnpm js:test:cloud",
    "js:test:cloud": "cross-env BROWSERSTACK=true pnpm js:test:karma",
    "js:test:debug": "cross-env DEBUG=true pnpm js:test:karma",
    "js:test:jquery": "cross-env JQUERY=true pnpm js:test:karma",
    "js:test:integration": "pnpm js:test:integration:bundle & pnpm js:test:integration:modularity",
    "js:test:integration:bundle": "rollup --config js/tests/integration/rollup.bundle.js",
    "js:test:integration:modularity": "rollup --config js/tests/integration/rollup.bundle-modularity.js",
    "js:test:karma": "karma start js/tests/karma.conf.js",
    "site": "pnpm site:build && pnpm site:lint",
    "site:build": "node build/build-site.js",
    "site:format": "prettier --write --cache site",
    "site:lint": "pnpm site:lint:prettier && pnpm site:lint:vnu",
    "site:lint:prettier": "prettier -c --cache site",
    "site:lint:vnu": "node build/vnu-jar.js",
    "astro:build": "astro build --root site",
    "astro:dev": "astro dev --root site --port 4322",
    "astro:preview": "astro preview --root site",
    "release": "pnpm dist && pnpm release:sri && pnpm site:build && pnpm release:zip",
    "release:sri": "node build/generate-sri.js",
    "release:version": "node build/change-version.js",
    "release:zip": "cross-env-shell \"rm -rf chassis-$npm_package_version-dist chassis-$npm_package_version-dist.zip && cp -r dist/ chassis-$npm_package_version-dist && zip -qr9 chassis-$npm_package_version-dist.zip chassis-$npm_package_version-dist && rm -rf chassis-$npm_package_version-dist\"",
    "watch": "pnpm --parallel \"/^watch:.*/\"",
    "watch-all": "pnpm watch:css:dist & pnpm watch:css:main & pnpm watch:css:site & pnpm watch:css:test & pnpm watch:js:main & pnpm watch:js:site",
    "watch:css:dist": "nodemon --watch dist/css/ --ext css --ignore \"dist/css/*.rtl.*\" --exec \"pnpm css:rtl\"",
    "watch:css:main": "nodemon --watch scss/ --ext scss --exec \"pnpm css:lint && pnpm css:compile && pnpm css:prefix\"",
    "watch:css:site": "nodemon --watch site/src/scss/ --ext scss --exec \"pnpm css:lint\"",
    "watch:css:test": "nodemon --watch scss/ --ext scss,js --exec \"pnpm css:test\"",
    "watch:js:main": "nodemon --watch js/src/ --ext js --exec \"pnpm js:lint && pnpm js:compile\"",
    "watch:js:site": "nodemon --watch site/src/assets/ --ext js --exec \"pnpm js:lint\"",
    "check": "pnpm check:bundle & pnpm check:code & pnpm check:lockfile & pnpm check:pnpm & wait",
    "check:bundle": "bundlewatch --config .bundlewatch.config.json",
    "check:code": "pnpm css:lint & pnpm js:lint & pnpm site:lint & wait",
    "check:lockfile": "lockfile-lint --allowed-hosts npm --allowed-schemes https: --empty-hostname false --type npm --path package-lock.json",
    "check:pnpm": "pnpm audit --audit-level moderate",
    "sync:submodules": "node build/sync-submodules.js"
  },
  "peerDependencies": {
    "@popperjs/core": "^2.11.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/markdown-remark": "^6.3.1",
    "@astrojs/mdx": "^4.2.6",
    "@astrojs/prism": "^3.2.0",
    "@astrojs/sitemap": "^3.3.1",
    "@chassis-ui/docs": "github:chassis-ui/docs/packages/docs#app/docs",
    "@chassis-ui/icons": "github:chassis-ui/icons#app/docs",
    "@chassis-ui/tokens": "github:chassis-ui/tokens#app/docs",
    "@docsearch/css": "^3.9.0",
    "@docsearch/js": "^3.9.0",
    "@eslint/js": "^9.35.0",
    "@eslint/markdown": "^7.2.0",
    "@popperjs/core": "^2.11.8",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-replace": "^6.0.2",
    "@stackblitz/sdk": "^1.11.0",
    "@types/google.analytics": "^0.0.46",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.5",
    "@types/mdast": "^4.0.4",
    "@types/mime": "^3.0.1",
    "@types/node": "^22.18.1",
    "@types/prismjs": "^1.26.0",
    "astro": "^5.7.10",
    "astro-auto-import": "^0.4.4",
    "autoprefixer": "^10.4.21",
    "bundlewatch": "^0.4.1",
    "clean-css-cli": "^5.6.3",
    "clipboard": "^2.0.11",
    "cross-env": "^7.0.3",
    "cspell": "^9.2.1",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-html": "^8.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^55.0.0",
    "find-unused-sass-variables": "^6.1.0",
    "fuse.js": "^7.1.0",
    "github-slugger": "^2.0.0",
    "globals": "^16.4.0",
    "globby": "^14.1.0",
    "hammer-simulator": "0.0.1",
    "htmlparser2": "^10.0.0",
    "image-size": "^2.0.2",
    "ip": "^2.0.1",
    "jasmine": "^5.6.0",
    "jquery": "^3.7.1",
    "js-yaml": "^4.1.0",
    "karma": "^6.4.4",
    "karma-browserstack-launcher": "1.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-detect-browsers": "^2.3.3",
    "karma-firefox-launcher": "^2.1.3",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "karma-rollup-preprocessor": "7.0.7",
    "lockfile-lint": "^4.14.1",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-to-string": "^4.0.0",
    "mime": "^4.0.7",
    "nodemon": "^3.1.10",
    "npm-run-all2": "^7.0.2",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prismjs": "^1.30.0",
    "rehype-autolink-headings": "^7.1.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "rollup": "^4.38.0",
    "rollup-plugin-istanbul": "^5.0.0",
    "rtlcss": "^4.3.0",
    "sass": "1.78.0",
    "sass-true": "^8.1.0",
    "shelljs": "^0.9.2",
    "stylelint": "^16.24.0",
    "stylelint-config-twbs-bootstrap": "^16.1.0",
    "terser": "^5.39.0",
    "typescript-eslint": "^8.44.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vnu-jar": "24.10.17",
    "zod": "^3.24.3"
  },
  "files": [
    "dist/{css,js}/*.{css,js,map}",
    "js/{src,dist}/**/*.{js,map}",
    "js/index.{esm,umd}.js",
    "scss/**/*.scss",
    "!scss/tests/**"
  ],
  "jspm": {
    "registry": "npm",
    "main": "js/chassis",
    "directories": {
      "lib": "dist"
    },
    "shim": {
      "js/chassis": {
        "deps": [
          "@popperjs/core"
        ]
      }
    },
    "dependencies": {},
    "peerDependencies": {
      "@popperjs/core": "^2.11.8"
    }
  },
  "packageManager": "pnpm@10.7.0+sha512.6b865ad4b62a1d9842b61d674a393903b871d9244954f652b8842c2b553c72176b278f64c463e52d40fff8aba385c235c8c9ecf5cc7de4fd78b8bb6d49633ab6",
  "pnpm": {
    "overrides": {}
  }
}
