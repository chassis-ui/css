{
  "name": "@chassis-ui/css",
  "description": "A CSS framework which synchronizes with Figma components by using design tokens.",
  "version": "0.3.2",
  "type": "module",
  "config": {
    "version_short": "0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "css",
    "sass",
    "mobile-first",
    "responsive",
    "front-end",
    "framework",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chassis-ui/css.git"
  },
  "bugs": {
    "url": "https://github.com/chassis-ui/css/issues"
  },
  "homepage": "https://chassis-ui.com",
  "author": "Ozgur Gunes <o.gunes@gmail.com>",
  "license": "MIT",
  "sass": "scss/chassis.scss",
  "style": "dist/css/chassis.css",
  "sideEffects": [
    "./js/index.js",
    "./js/src/*.js",
    "./js/dist/*.js",
    "./dist/js/*.js"
  ],
  "exports": {
    ".": "./js/index.js",
    "./js/src/*": "./js/src/*",
    "./js/dist/*": "./js/dist/*",
    "./dist/js/*": "./dist/js/*",
    "./dist/css/*": "./dist/css/*",
    "./scss/*": "./scss/*"
  },
  "scripts": {
    "build": "pnpm dist && pnpm site:build",
    "start": "pnpm dist && pnpm sync-submodules && pnpm dev",
    "dev": "run-p watch astro:dev",
    "dist": "run-p css js",
    "test": "pnpm check:code && pnpm dist && pnpm css:test && pnpm js:test && pnpm site:build && pnpm site:lint",
    "css": "pnpm css:compile && pnpm css:prefix && pnpm css:minify",
    "css:compile": "sass --load-path scss/vendor/ --load-path node_modules --style expanded --source-map --embed-sources scss/:dist/css/",
    "css:lint": "run-p css:lint:stylelint css:lint:vars",
    "css:lint:imports": "node build/check-imports.js scss/ site/src/scss/",
    "css:lint:stylelint": "stylelint \"**/*.{css,scss}\" \"!vendor/**\" --cache --cache-location .cache/.stylelintcache",
    "css:lint:vars": "fusv scss/ site/src/scss/ || true",
    "css:minify": "node build/css-minify.js",
    "css:prefix": "postcss --config build/postcss.config.js --replace \"dist/css/*.css\" \"!dist/css/*.min.css\"",
    "css:test": "jasmine --config=scss/tests/jasmine.cjs",
    "css:test:legacy": "node scss/tests/runner.js",
    "js": "pnpm js:compile && pnpm js:minify",
    "js:compile": "run-p js:compile:standalone js:compile:bundle js:compile:plugins",
    "js:compile:standalone": "rollup --environment BUNDLE:false --config build/rollup.config.js --sourcemap",
    "js:compile:bundle": "rollup --environment BUNDLE:true --config build/rollup.config.js --sourcemap",
    "js:compile:plugins": "node build/build-plugins.js",
    "js:lint": "eslint --cache --cache-location .cache/.eslintcache --report-unused-disable-directives --ext .html,.js,.cjs,.mjs,.md .",
    "js:minify": "run-p js:minify:standalone js:minify:bundle",
    "js:minify:standalone": "terser --compress passes=2 --mangle --comments \"/^!/\" --source-map \"content=dist/js/chassis.js.map,includeSources,url=chassis.min.js.map\" --output dist/js/chassis.min.js dist/js/chassis.js",
    "js:minify:bundle": "terser --compress passes=2 --mangle --comments \"/^!/\" --source-map \"content=dist/js/chassis.bundle.js.map,includeSources,url=chassis.bundle.min.js.map\" --output dist/js/chassis.bundle.min.js dist/js/chassis.bundle.js",
    "js:test": "run-p js:test:karma js:test:cloud",
    "js:test:cloud": "cross-env BROWSERSTACK=true pnpm js:test:karma",
    "js:test:debug": "cross-env DEBUG=true pnpm js:test:karma",
    "js:test:integration": "run-p js:test:integration:bundle js:test:integration:modularity",
    "js:test:integration:bundle": "rollup --config js/tests/integration/rollup.bundle.js",
    "js:test:integration:modularity": "rollup --config js/tests/integration/rollup.bundle-modularity.js",
    "js:test:karma": "karma start js/tests/karma.conf.js",
    "site": "pnpm site:build && pnpm site:lint",
    "site:build": "pnpm sync-submodules && pnpm astro:build && pnpm site:pagefind",
    "site:clean": "rm -rf _site site/node_modules site/.astro site/public",
    "site:lint": "pnpm site:lint:eslint && pnpm site:lint:prettier && pnpm site:lint:vnu",
    "site:lint:eslint": "eslint site --cache --cache-location .cache/.eslintcache --report-unused-disable-directives",
    "site:lint:prettier": "prettier -c --cache site",
    "site:lint:vnu": "node build/vnu-jar.js",
    "site:lint:html": "node build/html-validate.js",
    "site:pagefind": "pagefind --site _site",
    "astro:build": "astro build --root site",
    "astro:dev": "astro dev --root site --port 4323 --host",
    "astro:preview": "astro preview --root site",
    "release": "pnpm dist && pnpm release:sri && pnpm site:build && pnpm release:zip",
    "release:sri": "node build/generate-sri.js",
    "release:zip": "cross-env-shell \"rm -rf chassis-$npm_package_version-dist chassis-$npm_package_version-dist.zip && cp -r dist/ chassis-$npm_package_version-dist && zip -qr9 chassis-$npm_package_version-dist.zip chassis-$npm_package_version-dist && rm -rf chassis-$npm_package_version-dist\"",
    "watch": "run-p watch:css:main watch:css:site watch:css:test watch:js:main watch:js:site",
    "watch:css:dist": "nodemon --watch dist/css/ --ext css",
    "watch:css:main": "nodemon --watch scss/ --ext scss --exec \"pnpm css:lint; pnpm css:compile && pnpm css:prefix\"",
    "watch:css:site": "nodemon --watch site/src/scss/ --ext scss --exec \"pnpm css:lint\"",
    "watch:css:test": "nodemon --watch scss/ --ext scss,js --exec \"pnpm css:test\"",
    "watch:js:main": "nodemon --watch js/src/ --ext js --exec \"pnpm js:lint && pnpm js:compile\"",
    "watch:js:site": "nodemon --watch site/src/assets/ --ext js --exec \"pnpm js:lint\"",
    "check": "run-p check:bundle check:code check:lockfile check:pnpm",
    "check:astro": "astro check --root site",
    "check:bundle": "bundlewatch --config .bundlewatch.config.json",
    "check:code": "run-p css:lint js:lint site:lint",
    "check:lockfile": "lockfile-lint --allowed-hosts npm --allowed-schemes https: --empty-hostname false --type npm --path package-lock.json",
    "check:pnpm": "pnpm audit --audit-level moderate",
    "change-version": "node build/change-version.js",
    "sync-submodules": "node build/sync-submodules.js"
  },
  "peerDependencies": {
    "@floating-ui/dom": "^1.7.6",
    "postcss-prefix-custom-properties": "^0.1.0",
    "vanilla-calendar-pro": "^3.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@chassis-ui/docs": "^0.3.3",
    "@chassis-ui/icons": "^0.3.0",
    "@chassis-ui/tokens": "^0.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.3",
    "@floating-ui/dom": "^1.7.6",
    "@pagefind/component-ui": "^1.5.2",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@shikijs/transformers": "^4.3.1",
    "@stackblitz/sdk": "^1.11.1",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.0",
    "astro": "^7.0.6",
    "autoprefixer": "^10.5.2",
    "bundlewatch": "^0.4.2",
    "clipboard": "^2.0.11",
    "cross-env": "^10.1.0",
    "cspell": "^10.0.1",
    "culori": "^4.0.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unicorn": "^70.0.0",
    "find-unused-sass-variables": "^6.2.1",
    "github-slugger": "^2.0.0",
    "globals": "^17.7.0",
    "globby": "^16.2.0",
    "hammer-simulator": "0.0.1",
    "html-validate": "11.5.5",
    "htmlparser2": "^12.0.0",
    "image-size": "^2.0.2",
    "ip": "^2.0.1",
    "jasmine": "^6.3.0",
    "js-yaml": "^5.2.1",
    "karma": "^6.4.4",
    "karma-browserstack-launcher": "1.6.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-detect-browsers": "^2.3.3",
    "karma-firefox-launcher": "^2.1.3",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "karma-rollup-preprocessor": "7.0.8",
    "lightningcss": "^1.32.0",
    "lockfile-lint": "^5.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-to-string": "^4.0.0",
    "nodemon": "^3.1.14",
    "npm-run-all2": "^9.0.2",
    "pagefind": "^1.5.2",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.16",
    "postcss-cli": "^11.0.1",
    "postcss-prefix-custom-properties": "^0.1.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-autolink-headings": "^7.1.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "rollup": "^4.62.2",
    "rollup-plugin-istanbul": "^5.0.0",
    "sass": "^1.101.0",
    "sass-true": "^10.1.0",
    "shelljs": "^0.10.0",
    "stylelint": "^16.26.1",
    "shiki": "^4.3.1",
    "stylelint-config-twbs-bootstrap": "^16.1.0",
    "terser": "^5.48.0",
    "typescript-eslint": "^8.62.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vnu-jar": "^26.7.3",
    "zod": "^4.4.3"
  },
  "files": [
    "dist/{css,js}/*.{css,js,map}",
    "js/{src,dist}/**/*.{js,map}",
    "js/index.js",
    "scss/**/*.scss",
    "!scss/tests/**"
  ],
  "jspm": {
    "registry": "npm",
    "main": "js/chassis",
    "directories": {
      "lib": "dist"
    },
    "shim": {
      "js/chassis": {
        "deps": [
          "@floating-ui/dom"
        ]
      }
    },
    "dependencies": {},
    "peerDependencies": {
      "@floating-ui/dom": "^1.7.6"
    }
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
